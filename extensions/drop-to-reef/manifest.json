{
  "manifest_version": 3,
  "name": "Drop to Reef",
  "version": "0.1.0",
  "description": "Save the current page or highlighted text into a local MemoReef vault.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*"],
  "action": {
    "default_title": "Drop to Reef",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "drop-to-reef@memoreef.local",
      "strict_min_version": "109.0"
    }
  }
}
